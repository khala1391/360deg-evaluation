# Email Configuration (SMTP) - Optional
# If not set, passwords will be shown in Admin Panel only (no email sent)
# You can use any SMTP: Gmail App Password, Hostinger, SendGrid, etc.
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Server Configuration
PORT=3000
SESSION_SECRET=change-this-to-a-random-secret-key-in-production

# Admin Configuration
ADMIN_EMAIL=admin@365holding.co.th
ADMIN_PASSWORD=admin360eval
